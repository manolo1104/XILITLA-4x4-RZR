# ══════════════════════════════════════════════
# VARIABLES DE ENTORNO — Panel Axilitla 4x4
# Copia este archivo como ".env" y llena los valores
# ══════════════════════════════════════════════

# Clave secreta para las sesiones (pon cualquier texto largo)
SESSION_SECRET=cambia-esto-por-algo-secreto

# Puerto local (opcional, por defecto 3000)
# PORT=3000

# ── Vercel KV (base de datos en la nube) ──────
# Estas variables las agrega Vercel automáticamente
# cuando conectas un KV Store en el dashboard de Vercel.
# No las llenes manualmente, Vercel lo hace solo.
KV_REST_API_URL=
KV_REST_API_TOKEN=
